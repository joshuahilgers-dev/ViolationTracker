# Copy this file to `.env`, then fill in the real values.
# Do not commit the real `.env` file to GitHub.

# Server
PORT=4173
SESSION_SECRET=replace-with-a-long-random-string
SESSION_HOURS=8

# Google OAuth
# This sign-in flow requires the Client ID. The Client Secret is stored here for
# reference/future server-side OAuth flows, but is not used by the current login.
GOOGLE_CLIENT_ID=replace-with-your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-with-your-client-secret

# Access rules
ALLOWED_EMAIL_DOMAIN=wrps.net
BLOCKED_EMAIL_DOMAINS=stu.wrps.net

# Local testing only. Do not enable this on the production server.
AUTH_DISABLED=0
